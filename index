<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Collection Page Content Generator | Evolution Golf</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Georgia&family=Inter:wght@400;500;600&display=swap" rel="stylesheet">
    <style>
        :root {
            --primary-green: #006747;
            --dark-green: #004d35;
            --gold: #c9a227;
            --dark-bg: #1a1a1a;
            --light-bg: #f8f9fa;
            --border: #e0e0e0;
            --text: #333;
            --text-muted: #666;
            --white: #ffffff;
            --error: #dc3545;
            --success: #28a745;
        }

        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        body {
            font-family: 'Inter', -apple-system, sans-serif;
            background: var(--light-bg);
            color: var(--text);
            line-height: 1.6;
            min-height: 100vh;
        }

        /* Header */
        .header {
            background: var(--dark-bg);
            padding: 1.5rem 2rem;
            border-bottom: 3px solid var(--gold);
        }

        .header-content {
            max-width: 900px;
            margin: 0 auto;
            display: flex;
            align-items: center;
            gap: 1rem;
        }

        .logo {
            width: 48px;
            height: 48px;
            background: var(--primary-green);
            border-radius: 8px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-family: 'Georgia', serif;
            font-size: 1.5rem;
            color: var(--white);
            font-weight: bold;
        }

        .header h1 {
            font-family: 'Georgia', serif;
            font-size: 1.5rem;
            color: var(--white);
            font-weight: normal;
        }

        .header h1 span {
            color: var(--gold);
        }

        /* Main Container */
        .container {
            max-width: 900px;
            margin: 0 auto;
            padding: 2rem;
        }

        /* Form Card */
        .form-card {
            background: var(--white);
            border-radius: 12px;
            box-shadow: 0 2px 12px rgba(0,0,0,0.08);
            overflow: hidden;
        }

        .form-header {
            background: var(--primary-green);
            padding: 1.25rem 2rem;
            color: var(--white);
        }

        .form-header h2 {
            font-size: 1.1rem;
            font-weight: 600;
            margin-bottom: 0.25rem;
        }

        .form-header p {
            font-size: 0.875rem;
            opacity: 0.9;
        }

        .form-body {
            padding: 2rem;
        }

        /* Form Groups */
        .form-group {
            margin-bottom: 1.75rem;
        }

        .form-group:last-child {
            margin-bottom: 0;
        }

        label {
            display: block;
            font-weight: 500;
            margin-bottom: 0.5rem;
            color: var(--text);
        }

        label .required {
            color: var(--error);
        }

        .label-hint {
            font-weight: 400;
            font-size: 0.8rem;
            color: var(--text-muted);
            display: block;
            margin-top: 0.25rem;
        }

        /* Inputs */
        input[type="text"],
        input[type="url"],
        textarea {
            width: 100%;
            padding: 0.75rem 1rem;
            border: 2px solid var(--border);
            border-radius: 8px;
            font-size: 0.95rem;
            font-family: inherit;
            transition: border-color 0.2s, box-shadow 0.2s;
        }

        input[type="text"]:focus,
        input[type="url"]:focus,
        textarea:focus {
            outline: none;
            border-color: var(--primary-green);
            box-shadow: 0 0 0 3px rgba(0, 103, 71, 0.1);
        }

        textarea {
            resize: vertical;
            min-height: 100px;
        }

        /* Products Section */
        .products-section {
            background: var(--light-bg);
            border-radius: 8px;
            padding: 1.25rem;
            margin-top: 0.5rem;
        }

        .product-list {
            display: flex;
            flex-direction: column;
            gap: 0.75rem;
        }

        .product-item {
            display: flex;
            gap: 0.75rem;
            align-items: center;
        }

        .product-item input {
            flex: 1;
        }

        .btn-remove {
            width: 36px;
            height: 36px;
            border: none;
            background: var(--white);
            border: 2px solid var(--border);
            border-radius: 6px;
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            transition: all 0.2s;
            color: var(--text-muted);
        }

        .btn-remove:hover {
            border-color: var(--error);
            color: var(--error);
            background: #fff5f5;
        }

        .btn-add {
            margin-top: 0.75rem;
            padding: 0.6rem 1rem;
            background: var(--white);
            border: 2px dashed var(--border);
            border-radius: 8px;
            cursor: pointer;
            font-size: 0.875rem;
            color: var(--text-muted);
            transition: all 0.2s;
            display: flex;
            align-items: center;
            gap: 0.5rem;
            justify-content: center;
        }

        .btn-add:hover {
            border-color: var(--primary-green);
            color: var(--primary-green);
            background: rgba(0, 103, 71, 0.03);
        }

        /* Manufacturer Links Section */
        .links-section {
            background: var(--light-bg);
            border-radius: 8px;
            padding: 1.25rem;
            margin-top: 0.5rem;
        }

        .link-list {
            display: flex;
            flex-direction: column;
            gap: 0.75rem;
        }

        .link-item {
            display: flex;
            gap: 0.75rem;
            align-items: center;
        }

        .link-item input {
            flex: 1;
        }

        /* Two Column Layout */
        .form-row {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 1.5rem;
        }

        @media (max-width: 640px) {
            .form-row {
                grid-template-columns: 1fr;
            }
        }

        /* Submit Button */
        .form-actions {
            margin-top: 2rem;
            padding-top: 1.5rem;
            border-top: 1px solid var(--border);
            display: flex;
            gap: 1rem;
            align-items: center;
        }

        .btn-submit {
            background: var(--primary-green);
            color: var(--white);
            border: none;
            padding: 0.875rem 2rem;
            font-size: 1rem;
            font-weight: 600;
            border-radius: 8px;
            cursor: pointer;
            transition: background 0.2s, transform 0.1s;
            display: flex;
            align-items: center;
            gap: 0.5rem;
        }

        .btn-submit:hover {
            background: var(--dark-green);
        }

        .btn-submit:active {
            transform: scale(0.98);
        }

        .btn-submit:disabled {
            background: var(--text-muted);
            cursor: not-allowed;
        }

        .btn-reset {
            background: transparent;
            color: var(--text-muted);
            border: 2px solid var(--border);
            padding: 0.75rem 1.5rem;
            font-size: 0.95rem;
            font-weight: 500;
            border-radius: 8px;
            cursor: pointer;
            transition: all 0.2s;
        }

        .btn-reset:hover {
            border-color: var(--text-muted);
            color: var(--text);
        }

        /* Status Messages */
        .status {
            margin-top: 1rem;
            padding: 1rem;
            border-radius: 8px;
            display: none;
        }

        .status.success {
            display: block;
            background: #d4edda;
            border: 1px solid #c3e6cb;
            color: #155724;
        }

        .status.error {
            display: block;
            background: #f8d7da;
            border: 1px solid #f5c6cb;
            color: #721c24;
        }

        .status.loading {
            display: flex;
            align-items: center;
            gap: 0.75rem;
            background: #e7f3ff;
            border: 1px solid #b6d4fe;
            color: #084298;
        }

        .spinner {
            width: 20px;
            height: 20px;
            border: 2px solid #b6d4fe;
            border-top-color: #084298;
            border-radius: 50%;
            animation: spin 0.8s linear infinite;
        }

        @keyframes spin {
            to { transform: rotate(360deg); }
        }

        /* Footer */
        .footer {
            text-align: center;
            padding: 2rem;
            color: var(--text-muted);
            font-size: 0.875rem;
        }

        .footer a {
            color: var(--primary-green);
            text-decoration: none;
        }

        /* Webhook Config */
        .config-panel {
            background: var(--white);
            border-radius: 12px;
            box-shadow: 0 2px 12px rgba(0,0,0,0.08);
            padding: 1.5rem 2rem;
            margin-bottom: 1.5rem;
        }

        .config-panel summary {
            cursor: pointer;
            font-weight: 600;
            color: var(--text);
            display: flex;
            align-items: center;
            gap: 0.5rem;
        }

        .config-panel summary::-webkit-details-marker {
            display: none;
        }

        .config-panel[open] summary {
            margin-bottom: 1rem;
        }

        .config-content {
            padding-top: 0.5rem;
        }

        .config-content label {
            font-weight: 500;
            font-size: 0.875rem;
        }

        .config-content input {
            font-family: 'SF Mono', Monaco, 'Courier New', monospace;
            font-size: 0.875rem;
        }
    </style>
</head>
<body>
    <header class="header">
        <div class="header-content">
            <div class="logo">E</div>
            <h1>Collection Page <span>Content Generator</span></h1>
        </div>
    </header>

    <main class="container">
        <!-- Webhook Configuration -->
        <details class="config-panel">
            <summary>
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <circle cx="12" cy="12" r="3"></circle>
                    <path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1 0 2.83 2 2 0 0 1-2.83 0l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-2 2 2 2 0 0 1-2-2v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83 0 2 2 0 0 1 0-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1-2-2 2 2 0 0 1 2-2h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 0-2.83 2 2 0 0 1 2.83 0l.06.06a1.65 1.65 0 0 0 1.82.33H9a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 2-2 2 2 0 0 1 2 2v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 0 2 2 0 0 1 0 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 2 2 2 2 0 0 1-2 2h-.09a1.65 1.65 0 0 0-1.51 1z"></path>
                </svg>
                Webhook Configuration
            </summary>
            <div class="config-content">
                <div class="form-group">
                    <label for="webhookUrl">n8n Webhook URL</label>
                    <input type="url" id="webhookUrl" placeholder="https://your-n8n-instance.app.n8n.cloud/webhook/..." value="">
                    <span class="label-hint">This URL is saved in your browser's local storage</span>
                </div>
            </div>
        </details>

        <!-- Main Form -->
        <form id="contentForm" class="form-card">
            <div class="form-header">
                <h2>Generate Collection Page Content</h2>
                <p>Fill in the details below to generate SEO-optimised content for a collection page</p>
            </div>

            <div class="form-body">
                <!-- Collection Page URL -->
                <div class="form-group">
                    <label for="pageUrl">
                        Collection Page URL <span class="required">*</span>
                    </label>
                    <input type="url" id="pageUrl" name="pageUrl" required 
                           placeholder="https://evolutiongolf.co.uk/collections/pxg-drivers">
                </div>

                <!-- Keywords Row -->
                <div class="form-row">
                    <div class="form-group">
                        <label for="primaryKeyword">
                            Primary Keyword <span class="required">*</span>
                        </label>
                        <input type="text" id="primaryKeyword" name="primaryKeyword" required
                               placeholder="e.g. PXG drivers">
                    </div>
                    <div class="form-group">
                        <label for="collectionSlug">
                            Collection Slug <span class="required">*</span>
                        </label>
                        <input type="text" id="collectionSlug" name="collectionSlug" required
                               placeholder="e.g. pxg-drivers">
                    </div>
                </div>

                <!-- Secondary Keywords -->
                <div class="form-group">
                    <label for="secondaryKeywords">
                        Secondary Keywords <span class="required">*</span>
                        <span class="label-hint">Comma-separated list of supporting keywords</span>
                    </label>
                    <input type="text" id="secondaryKeywords" name="secondaryKeywords" required
                           placeholder="e.g. PXG drivers UK, buy PXG driver, PXG golf drivers">
                </div>

                <!-- Products We Stock -->
                <div class="form-group">
                    <label>
                        Products We Stock <span class="required">*</span>
                        <span class="label-hint">Add each product in this collection</span>
                    </label>
                    <div class="products-section">
                        <div class="product-list" id="productList">
                            <div class="product-item">
                                <input type="text" name="products[]" placeholder="e.g. PXG Lightning Max 10K+ Driver" required>
                                <button type="button" class="btn-remove" onclick="removeProduct(this)" title="Remove">
                                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                        <line x1="18" y1="6" x2="6" y2="18"></line>
                                        <line x1="6" y1="6" x2="18" y2="18"></line>
                                    </svg>
                                </button>
                            </div>
                        </div>
                        <button type="button" class="btn-add" onclick="addProduct()">
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <line x1="12" y1="5" x2="12" y2="19"></line>
                                <line x1="5" y1="12" x2="19" y2="12"></line>
                            </svg>
                            Add Another Product
                        </button>
                    </div>
                </div>

                <!-- Manufacturer Links -->
                <div class="form-group">
                    <label>
                        Manufacturer Reference Links
                        <span class="label-hint">Links to manufacturer pages for accurate specs and features</span>
                    </label>
                    <div class="links-section">
                        <div class="link-list" id="linkList">
                            <div class="link-item">
                                <input type="url" name="manufacturerLinks[]" placeholder="e.g. https://www.pxg.com/en-gb/collections/drivers">
                                <button type="button" class="btn-remove" onclick="removeLink(this)" title="Remove">
                                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                        <line x1="18" y1="6" x2="6" y2="18"></line>
                                        <line x1="6" y1="6" x2="18" y2="18"></line>
                                    </svg>
                                </button>
                            </div>
                        </div>
                        <button type="button" class="btn-add" onclick="addLink()">
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <line x1="12" y1="5" x2="12" y2="19"></line>
                                <line x1="5" y1="12" x2="19" y2="12"></line>
                            </svg>
                            Add Another Link
                        </button>
                    </div>
                </div>

                <!-- Form Actions -->
                <div class="form-actions">
                    <button type="submit" class="btn-submit" id="submitBtn">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="M22 2L11 13"></path>
                            <path d="M22 2L15 22L11 13L2 9L22 2Z"></path>
                        </svg>
                        Generate Content
                    </button>
                    <button type="reset" class="btn-reset">Clear Form</button>
                </div>

                <!-- Status Message -->
                <div id="statusMessage" class="status"></div>
            </div>
        </form>

        <footer class="footer">
            <p>Evolution Golf Content Generator &middot; Powered by <a href="https://n8n.io" target="_blank">n8n</a> + Claude</p>
        </footer>
    </main>

    <script>
        // Load saved webhook URL
        document.addEventListener('DOMContentLoaded', () => {
            const savedUrl = localStorage.getItem('evoGolf_collectionWebhookUrl');
            if (savedUrl) {
                document.getElementById('webhookUrl').value = savedUrl;
            }
        });

        // Save webhook URL on change
        document.getElementById('webhookUrl').addEventListener('change', (e) => {
            localStorage.setItem('evoGolf_collectionWebhookUrl', e.target.value);
        });

        // Add product input
        function addProduct() {
            const list = document.getElementById('productList');
            const item = document.createElement('div');
            item.className = 'product-item';
            item.innerHTML = `
                <input type="text" name="products[]" placeholder="e.g. PXG Lightning Max 10K+ Driver" required>
                <button type="button" class="btn-remove" onclick="removeProduct(this)" title="Remove">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <line x1="18" y1="6" x2="6" y2="18"></line>
                        <line x1="6" y1="6" x2="18" y2="18"></line>
                    </svg>
                </button>
            `;
            list.appendChild(item);
        }

        // Remove product input
        function removeProduct(btn) {
            const list = document.getElementById('productList');
            if (list.children.length > 1) {
                btn.closest('.product-item').remove();
            }
        }

        // Add manufacturer link input
        function addLink() {
            const list = document.getElementById('linkList');
            const item = document.createElement('div');
            item.className = 'link-item';
            item.innerHTML = `
                <input type="url" name="manufacturerLinks[]" placeholder="e.g. https://www.pxg.com/en-gb/collections/drivers">
                <button type="button" class="btn-remove" onclick="removeLink(this)" title="Remove">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <line x1="18" y1="6" x2="6" y2="18"></line>
                        <line x1="6" y1="6" x2="18" y2="18"></line>
                    </svg>
                </button>
            `;
            list.appendChild(item);
        }

        // Remove manufacturer link input
        function removeLink(btn) {
            const list = document.getElementById('linkList');
            if (list.children.length > 1) {
                btn.closest('.link-item').remove();
            }
        }

        // Form submission
        document.getElementById('contentForm').addEventListener('submit', async (e) => {
            e.preventDefault();

            const webhookUrl = document.getElementById('webhookUrl').value;
            if (!webhookUrl) {
                showStatus('error', 'Please configure the webhook URL first (click the settings panel above)');
                return;
            }

            const submitBtn = document.getElementById('submitBtn');
            submitBtn.disabled = true;
            showStatus('loading', 'Sending to n8n workflow...');

            // Gather form data
            const products = Array.from(document.querySelectorAll('input[name="products[]"]'))
                .map(input => input.value.trim())
                .filter(v => v);

            const manufacturerLinks = Array.from(document.querySelectorAll('input[name="manufacturerLinks[]"]'))
                .map(input => input.value.trim())
                .filter(v => v);

            const payload = {
                page_url: document.getElementById('pageUrl').value.trim(),
                primary_keyword: document.getElementById('primaryKeyword').value.trim(),
                secondary_keywords: document.getElementById('secondaryKeywords').value.trim(),
                collection_slug: document.getElementById('collectionSlug').value.trim(),
                products_stocked: products.join('|'),
                products_list: products.map(p => `- ${p}`).join('\n'),
                manufacturer_links: manufacturerLinks.join('|'),
                manufacturer_links_list: manufacturerLinks.map(l => `- ${l}`).join('\n')
            };

            try {
                const response = await fetch(webhookUrl, {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json'
                    },
                    body: JSON.stringify(payload)
                });

                if (response.ok) {
                    const result = await response.text();
                    showStatus('success', `✓ Content generation triggered successfully! Check your n8n workflow for the output.`);
                    // Optionally reset form
                    // document.getElementById('contentForm').reset();
                } else {
                    throw new Error(`Webhook returned ${response.status}: ${response.statusText}`);
                }
            } catch (error) {
                console.error('Submission error:', error);
                showStatus('error', `Failed to trigger workflow: ${error.message}`);
            } finally {
                submitBtn.disabled = false;
            }
        });

        // Show status message
        function showStatus(type, message) {
            const status = document.getElementById('statusMessage');
            status.className = 'status ' + type;
            
            if (type === 'loading') {
                status.innerHTML = `<div class="spinner"></div><span>${message}</span>`;
            } else {
                status.textContent = message;
            }
        }

        // Clear status on form reset
        document.getElementById('contentForm').addEventListener('reset', () => {
            document.getElementById('statusMessage').className = 'status';
            document.getElementById('statusMessage').textContent = '';
            
            // Reset to single product/link inputs
            document.getElementById('productList').innerHTML = `
                <div class="product-item">
                    <input type="text" name="products[]" placeholder="e.g. PXG Lightning Max 10K+ Driver" required>
                    <button type="button" class="btn-remove" onclick="removeProduct(this)" title="Remove">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <line x1="18" y1="6" x2="6" y2="18"></line>
                            <line x1="6" y1="6" x2="18" y2="18"></line>
                        </svg>
                    </button>
                </div>
            `;
            document.getElementById('linkList').innerHTML = `
                <div class="link-item">
                    <input type="url" name="manufacturerLinks[]" placeholder="e.g. https://www.pxg.com/en-gb/collections/drivers">
                    <button type="button" class="btn-remove" onclick="removeLink(this)" title="Remove">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <line x1="18" y1="6" x2="6" y2="18"></line>
                            <line x1="6" y1="6" x2="18" y2="18"></line>
                        </svg>
                    </button>
                </div>
            `;
        });
    </script>
</body>
</html>
